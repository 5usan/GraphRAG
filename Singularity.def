Bootstrap: docker
From: python:3.11-slim

%labels
  Maintainer "Susan Shrestha"
  Description "GraphRAG: Retrieval-Augmented Generation for Question Answering over Knowledge Graphs"
  Version "1.0"

%environment
  export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
  export PYTHONUNBUFFERED=1
  export PYTHONDONTWRITEBYTECODE=1
  export PYTHONPATH=/app/src:$PYTHONPATH

%post
  # Update and install system dependencies in one layer (reduces container size)
  apt-get update && \
  apt-get install -y --no-install-recommends \
    build-essential \
    git \
    curl \
  && apt-get clean && \
  rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

  # Upgrade pip, setuptools, wheel
  pip install --no-cache-dir --upgrade pip setuptools wheel

%files
  requirements.txt /app/requirements.txt
  src /app/src

%post
  # Install Python dependencies (separate for better caching)
  pip install --no-cache-dir -r /app/requirements.txt
  
  # Set working directory
  mkdir -p /app/src

%runscript
  cd /app/src
  exec uvicorn main:app --host 0.0.0.0 --port 8000